{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "InputBucketLevelActions",
      "Effect": "Allow",
      "Action": ["s3:GetBucketLocation", "s3:ListBucket"],
      "Resource": ["arn:aws:s3:::input"]
    },
    {
      "Sid": "InputReadWriteActions",
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": ["arn:aws:s3:::input/*"]
    },
    {
      "Sid": "OutputBucketLevelActions",
      "Effect": "Allow",
      "Action": ["s3:GetBucketLocation", "s3:ListBucket"],
      "Resource": ["arn:aws:s3:::output"]
    },
    {
      "Sid": "OutputReadWriteActions",
      "Effect": "Allow",
      "Action": ["s3:AbortMultipartUpload", "s3:GetObject", "s3:PutObject"],
      "Resource": ["arn:aws:s3:::output/*"]
    }
  ]
}
